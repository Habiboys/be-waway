DB_USER=root
DB_PASSWORD=
DB_NAME=waway
DB_HOST=127.0.0.1
DB_DIALECT=mysql
DB_PORT=3306

PORT=3000
APP_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
JWT_SECRET=please-change-this-secret-and-long-random
JWT_EXPIRES_IN=1d

# WhatsApp / Puppeteer runtime
# If empty, service will auto-detect or use Puppeteer managed browser
CHROME_PATH=
PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_CACHE_DIR=/www/wwwroot/.cache/puppeteer
WA_HEADLESS=true
# Comma-separated args, example:
# WA_PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage
WA_PUPPETEER_ARGS=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
MAIL_APP_NAME=WA Blast
MAIL_LOGO_URL=